{
  "name": "@cublya/geomap",
  "version": "0.1.0",
  "description": "Composable React map primitives on d3-geo: country choropleths, globes, markers, great-circle routes, live objects and camera control.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src examples stories",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "serve-storybook": "http-server storybook-static -p 6006 -s",
    "test-storybook": "test-storybook",
    "test-storybook:ci": "concurrently -k -s first \"npm:serve-storybook\" \"wait-on tcp:127.0.0.1:6006 && test-storybook --url http://127.0.0.1:6006\"",
    "test:e2e": "playwright test",
    "prepack": "npm run build",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && publint && npm pack --dry-run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@types/d3-geo": "3.1.0",
    "@types/geojson": "7946.0.16",
    "@types/topojson-specification": "1.0.5",
    "d3-geo": "^3.1.1",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@storybook/test-runner": "0.24.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/topojson-client": "3.1.5",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "10.0.3",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "http-server": "14.1.1",
    "i18n-iso-countries": "7.14.0",
    "jsdom": "29.1.1",
    "publint": "0.3.21",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "storybook": "10.4.6",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "wait-on": "9.0.10",
    "world-atlas": "2.0.2"
  },
  "keywords": [
    "react",
    "map",
    "globe",
    "d3-geo",
    "choropleth",
    "topojson",
    "geojson",
    "great-circle",
    "svg"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cublya/geo.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
