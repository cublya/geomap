{
  "name": "@cublya/geo",
  "version": "0.1.0",
  "description": "Composable React map primitives on d3-geo: country choropleths, globes, markers, great-circle routes, live objects and camera control.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src examples",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && npm pack --dry-run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/d3-geo": "3.1.0",
    "@types/geojson": "7946.0.16",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/topojson-client": "3.1.5",
    "@types/topojson-specification": "1.0.5",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "i18n-iso-countries": "7.14.0",
    "jsdom": "29.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10",
    "world-atlas": "2.0.2"
  },
  "keywords": [
    "react",
    "map",
    "globe",
    "d3-geo",
    "choropleth",
    "topojson",
    "geojson",
    "great-circle",
    "svg"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cublya/geo.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
